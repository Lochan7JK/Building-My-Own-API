<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>My Blog</title>
  <!-- <link rel="stylesheet" href="/styles/main.css" /> -->
   <link rel="stylesheet" href="/styles/updatedMain.css" />
</head>

<body>
  <header class="navbar">
    <h1>📝 My Blogs</h1>
    <a class="btn btn-success" href="/new">+ New Post</a>
  </header>

  <main class="container">
    <% posts.forEach(post => { %>
      <article class="post-card">
        <div class="post-header">
          <h2><%= post.title %></h2>
          <span class="post-date">
            <%= new Date(post.date).toDateString() %>
          </span>
        </div>

        <p class="post-content">
          <%= post.content.length > 250 
              ? post.content.substring(0, 250) + "..." 
              : post.content %>
        </p>

        <div class="post-footer">
          <span class="author">✍️ <%= post.author %></span>

          <div class="actions">
            <a class="btn btn-edit" href="/edit/<%= post.id %>">Edit</a>
            <a class="btn btn-delete" href="/api/posts/delete/<%= post.id %>">
              Delete
            </a>
          </div>
        </div>
      </article>
    <% }) %>
  </main>
</body>
</html>
